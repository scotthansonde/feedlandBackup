    <outline text="February 2026" created="Sun, 01 Feb 2026 08:32:26 GMT" name="february2026" type="calendarMonth">
      <outline text="February 25" created="Wed, 25 Feb 2026 12:09:23 GMT" type="calendarDay" name="25">
        <outline text="Vacation" created="Wed, 25 Feb 2026 12:09:24 GMT" type="outline">
          <outline text="We'll be out of office and away from home until March 7" created="Wed, 25 Feb 2026 12:09:26 GMT"/>
        </outline>
      </outline>
      <outline text="February 23" created="Mon, 23 Feb 2026 14:50:33 GMT" type="calendarDay" name="23">
        <outline text="FeedLand http access in local network" created="Mon, 23 Feb 2026 14:50:34 GMT" type="outline">
          <outline text="Frank McPherson wanted to access his http-localhost Feedland on his local network" created="Mon, 23 Feb 2026 14:50:58 GMT" type="link" url="https://github.com/scotthansonde/feedlandDockerCompose/issues/8"/>
          <outline text="Trick is to set the url settings in config.json to a ip address or hostname, but leave myDomain as localhost" created="Mon, 23 Feb 2026 14:51:29 GMT">
            <outline text="&quot;urlWebsocketServerForClient&quot;: &quot;ws://192.168.1.34:1462/&quot;," created="Mon, 23 Feb 2026 14:52:34 GMT"/>
            <outline text="&quot;myDomain&quot;: &quot;localhost:1452&quot;,"/>
            <outline text="&quot;urlFeedlandApp&quot;: &quot;http://192.168.1.34:1452/&quot;,"/>
            <outline text="&quot;urlServerForClient&quot;: &quot;http://192.168.1.34:1452/&quot;,"/>
            <outline text="&quot;urlServerForEmail&quot;: &quot;http://192.168.1.34:1452/&quot;," created="Mon, 23 Feb 2026 14:52:43 GMT"/>
          </outline>
          <outline text="Not really a Docker issue, but it's nice to know how to do it" created="Mon, 23 Feb 2026 14:53:41 GMT"/>
        </outline>
      </outline>
      <outline text="February 20" created="Fri, 20 Feb 2026 09:49:08 GMT" type="calendarDay" name="20">
        <outline text="Thanks for the heads up on Chuck's name" created="Fri, 20 Feb 2026 16:18:48 GMT" type="outline">
          <outline text="I've been in Germany too long, I unconsciously Germanized his name  😃" created="Fri, 20 Feb 2026 16:19:00 GMT"/>
        </outline>
        <outline text="I announced the feedlandDockerCompose update" created="Fri, 20 Feb 2026 09:49:09 GMT" type="link" url="https://linkblog.scotthanson.de/2026/02/20/feedland-docker-compose-for-localhost/">
          <outline text="I have been linking to the GitHub repo, but I can make it more explicit" created="Fri, 20 Feb 2026 16:23:00 GMT"/>
          <outline text="" created="Fri, 20 Feb 2026 16:23:25 GMT"/>
        </outline>
      </outline>
      <outline text="February 19" created="Thu, 19 Feb 2026 10:05:27 GMT" type="calendarDay" name="19">
        <outline text="I'm fine with announcing the update to feedlandDockerCompose tomorrow 😃 " created="Thu, 19 Feb 2026 15:33:27 GMT" type="outline">
          <outline text="Draft text" created="Thu, 19 Feb 2026 16:15:27 GMT">
            <outline text="When I was creating the FeedLand Docker Compose file, I was thinking of it running on a VPS with a public hostname. There was another use case I was not thinking about: running on a local machine in a private network, without any hostname in DNS. This would be pretty common for someone just wanting to run FeedLand for themselves on their own laptop, without wanting to set up any SSL or proxy. " created="Thu, 19 Feb 2026 16:15:52 GMT"/>
            <outline text="For this case I've added an option to run FeedLand as localhost. When the initial script is called as `./scripts/generate-env.sh --http-localhost`, the URL of FeedLand is set to http://localhost:1452, and the Caddy web proxy is not started."/>
            <outline text="I've also added a script to easily determine the confirmation URL for a new user when email has not been configured." created="Thu, 19 Feb 2026 16:16:03 GMT"/>
            <outline text="Thanks to John Johnston and Frank McPherson for suggesting and testing the localhost installation. This should make it even easier to explore FeedLand. " created="Thu, 19 Feb 2026 16:23:34 GMT"/>
          </outline>
        </outline>
        <outline text="My personal server is currently down, so I can't write an announcement of the new feedlandDockerCompose just yet." created="Thu, 19 Feb 2026 13:12:53 GMT" type="outline">
          <outline text="We could point to the latest release on GitHub" created="Thu, 19 Feb 2026 13:13:27 GMT" type="link" url="https://github.com/scotthansonde/feedlandDockerCompose/releases/latest"/>
          <outline text="10 minutes later my server is reachable again. I'll have an announcement in a couple of house later this afternoon." created="Thu, 19 Feb 2026 13:31:44 GMT"/>
        </outline>
        <outline text="feedlandDockerCompose: Add script to get pending confirmations " created="Thu, 19 Feb 2026 10:05:28 GMT" type="outline">
          <outline text="Both users wrote that the instructions to validate a user without email were confusing" created="Thu, 19 Feb 2026 10:06:14 GMT"/>
          <outline text="Since we have the database credentials in .env, we can query the database for the magicString" created="Thu, 19 Feb 2026 10:08:04 GMT"/>
          <outline text="And we can print the full url for the user to copy and paste into the browser" created="Thu, 19 Feb 2026 10:08:52 GMT">
            <outline text="✗ ./scripts/query-pending-confirmations.sh" created="Thu, 19 Feb 2026 10:09:34 GMT">
              <outline text="*************************** 1. row ***************************" created="Thu, 19 Feb 2026 10:10:11 GMT"/>
              <outline text="magicString: 2zw1prgwfp" created="Thu, 19 Feb 2026 10:09:38 GMT"/>
              <outline text="email: papascott@gmail.com" created="Thu, 19 Feb 2026 10:09:51 GMT"/>
              <outline text="flDeleted: 0"/>
              <outline text="screenname: test" created="Thu, 19 Feb 2026 10:09:52 GMT"/>
              <outline text="flNewUser: 1" created="Thu, 19 Feb 2026 10:09:53 GMT"/>
              <outline text="urlRedirect: http://localhost:1452/" created="Thu, 19 Feb 2026 10:09:56 GMT"/>
              <outline text="whenCreated: 2026-02-19 10:09:22" created="Thu, 19 Feb 2026 10:10:02 GMT"/>
              <outline text="Confirmation URLs:" created="Thu, 19 Feb 2026 10:10:12 GMT"/>
              <outline text="http://localhost:1452//userconfirms?emailConfirmCode=2zw1prgwfp" created="Thu, 19 Feb 2026 10:10:06 GMT"/>
            </outline>
          </outline>
          <outline text="Created release v1.0.1 with these changes" created="Thu, 19 Feb 2026 10:33:57 GMT"/>
        </outline>
        <outline text="feedlandDockerCompose: Add option to configure for localhost" created="Thu, 19 Feb 2026 10:18:47 GMT" type="outline">
          <outline text="Added an option:  ./scripts/generate-env.sh --http-localhost " created="Thu, 19 Feb 2026 10:19:53 GMT"/>
          <outline text="This generates a config.json for http://localhost:1452/ with no SSL proxy" created="Thu, 19 Feb 2026 10:21:33 GMT"/>
          <outline text="Both users reported success" created="Thu, 19 Feb 2026 10:19:08 GMT"/>
        </outline>
      </outline>
      <outline text="February 18" created="Wed, 18 Feb 2026 16:45:49 GMT" type="calendarDay" name="18">
        <outline text="&quot;what this means is i would need to access the RSS feed from the JS code embedded in the page&quot;" created="Wed, 18 Feb 2026 17:06:21 GMT" type="outline">
          <outline text="&quot;the JS code embedded in the page&quot; is the testing.js file on your server, right?" created="Wed, 18 Feb 2026 17:06:36 GMT"/>
          <outline text="&quot;access the RSS feed&quot; means it needs to know the wordpress url of the feed, right?" created="Wed, 18 Feb 2026 17:12:28 GMT"/>
          <outline text="If so, this should be possible." created="Wed, 18 Feb 2026 17:13:39 GMT"/>
        </outline>
        <outline text="Got off on a tangent today" created="Wed, 18 Feb 2026 16:46:54 GMT" type="outline">
          <outline text="Looking at publicFolder and its electron version made me think about Electric Drummer" created="Wed, 18 Feb 2026 16:47:12 GMT"/>
          <outline text="I left Electric Drummer on the wayside since I wasn't sure how to get it to work with current versions of Electron" created="Wed, 18 Feb 2026 16:47:52 GMT"/>
          <outline text="However, now we have AI..." created="Wed, 18 Feb 2026 16:48:34 GMT"/>
          <outline text="So I decided to play with the electron app for publicFolder to see if we could bump the Electron version from 7 to 12" created="Wed, 18 Feb 2026 16:48:43 GMT">
            <outline text="Electron 12 runs natively on arm64, i.e. M1 Macs" created="Wed, 18 Feb 2026 16:50:09 GMT"/>
          </outline>
          <outline text="It took over 30 iterations, but I finally got it going without any startup errors" created="Wed, 18 Feb 2026 16:52:33 GMT"/>
        </outline>
        <outline text="Got a success report on the localhost fix for feedlandDockerCompose 👍" created="Wed, 18 Feb 2026 16:45:50 GMT" type="outline"/>
      </outline>
      <outline text="February 17" created="Tue, 17 Feb 2026 07:58:53 GMT" type="calendarDay" name="17">
        <outline text="Request about links" created="Tue, 17 Feb 2026 14:38:07 GMT" type="outline">
          <outline text="I'll try to remember that" created="Tue, 17 Feb 2026 14:38:20 GMT"/>
          <outline text="I've fixed my links for the past couple of days" created="Tue, 17 Feb 2026 14:43:23 GMT"/>
        </outline>
        <outline text="We have stars and an issue on the &lt;a href=&quot;https://github.com/scotthansonde/feedlandDockerCompose&quot;&gt;feedlandDockerCompose&lt;/a&gt; repo ���� " created="Tue, 17 Feb 2026 07:58:54 GMT" type="link" url="https://github.com/scotthansonde/feedlandDockerCompose">
          <outline text="https://github.com/scotthansonde/feedlandDockerCompose" created="Tue, 17 Feb 2026 14:39:49 GMT" type="link" url="https://github.com/scotthansonde/feedlandDockerCompose"/>
          <outline text="The install script doesn't work with HTTP, I've got to fix that." created="Tue, 17 Feb 2026 08:00:56 GMT"/>
          <outline text="I didn't get any mails about the issue either  " created="Tue, 17 Feb 2026 14:35:57 GMT">
            <outline text="I guess even the creator of the repo has to update the watch options to &quot;All Activity&quot;" created="Tue, 17 Feb 2026 14:36:33 GMT"/>
          </outline>
          <outline text="I've got a &lt;a href=&quot;https://github.com/scotthansonde/feedlandDockerCompose/issues/3#issuecomment-3915074019&quot;&gt;fix&lt;/a&gt; for localhost that &quot;works for me&quot;, let's see if it works for them too " created="Tue, 17 Feb 2026 14:43:49 GMT" type="link" url="https://github.com/scotthansonde/feedlandDockerCompose/issues/3#issuecomment-3915074019"/>
        </outline>
      </outline>
      <outline text="February 15" created="Sun, 15 Feb 2026 09:03:10 GMT" type="calendarDay" name="15">
        <outline text="Taking a cue from Dave, I also moved past months into included outlines" created="Sun, 15 Feb 2026 16:23:36 GMT" type="outline"/>
        <outline text="daves3" created="Sun, 15 Feb 2026 09:03:11 GMT" type="outline">
          <outline text="I created an &lt;a href=&quot;https://github.com/scripting/s3/issues/2&quot;&gt;issue&lt;/a&gt; to be able to configure S3 options" created="Sun, 15 Feb 2026 09:03:15 GMT" type="link" url="https://github.com/scripting/s3/issues/2"/>
          <outline text="Then we'd be able to use other S3 providers by setting the appropriate endpoint" created="Sun, 15 Feb 2026 09:04:29 GMT"/>
          <outline text="Set up a &lt;a href=&quot;https://github.com/scripting/s3/issues/2#issuecomment-3904731522&quot;&gt;test with publicFolder&lt;/a&gt; on my machine" created="Sun, 15 Feb 2026 16:25:35 GMT" type="link" url="https://github.com/scripting/s3/issues/2#issuecomment-3904731522"/>
        </outline>
      </outline>
      <outline text="February 12" created="Thu, 12 Feb 2026 11:37:18 GMT" type="calendarDay" name="12">
        <outline text="Getting back to WordPress multisite" created="Thu, 12 Feb 2026 15:56:13 GMT" type="outline">
          <outline text="Can we remotely setup secondary sites for user we approve?" created="Thu, 12 Feb 2026 15:56:24 GMT"/>
          <outline text="Yes, but it's not in the WP API. We'd have to write our own API endpoint." created="Thu, 12 Feb 2026 15:56:59 GMT"/>
          <outline text="There are examples of this on GitHub" created="Thu, 12 Feb 2026 15:57:38 GMT">
            <outline text="&lt;a href=&quot;https://github.com/brettkrueger/multisite-rest-api&quot;&gt;https://github.com/brettkrueger/multisite-rest-api&lt;/a&gt;" created="Thu, 12 Feb 2026 16:30:29 GMT" type="link" url="https://github.com/brettkrueger/multisite-rest-api"/>
          </outline>
          <outline text="ChatGPT also gave me a blueprint" created="Thu, 12 Feb 2026 16:04:06 GMT">
            <outline text="Screenshot 1" created="Thu, 12 Feb 2026 16:19:16 GMT">
              <outline text="&lt;img src=&quot;https://f001.backblazeb2.com/file/scotthanson-images/outlines/creating-wp-mu-addsite-endpoint-1.png&quot;&gt;" created="Thu, 12 Feb 2026 16:15:28 GMT"/>
            </outline>
            <outline text="Screenshot 2" created="Thu, 12 Feb 2026 16:17:11 GMT">
              <outline text="&lt;img src=&quot;https://f001.backblazeb2.com/file/scotthanson-images/outlines/creating-wp-mu-addsite-endpoint-2.png&quot;&gt;" created="Thu, 12 Feb 2026 16:19:45 GMT"/>
            </outline>
            <outline text="&lt;a href=&quot;https://f001.backblazeb2.com/file/scotthanson-images/outlines/creating-wp-mu-addsite-endpoint-plugin.txt&quot;&gt;Reference plugin code&lt;/a&gt;" created="Thu, 12 Feb 2026 16:24:08 GMT"/>
            <outline text="The &lt;a href=&quot;https://chatgpt.com/share/698dfc54-23dc-8009-b75f-950317fbcd50&quot;&gt;entire chat&lt;/a&gt;, scroll down to my question &quot;I would like for a separate app to be able to instantiate MU subsites. How could that work, with the WP API?&quot; " created="Thu, 12 Feb 2026 16:04:15 GMT"/>
          </outline>
        </outline>
        <outline text="Dave, thanks for the update on the status of FeedLand" created="Thu, 12 Feb 2026 11:37:19 GMT" type="outline">
          <outline text="I'm pretty sure the Docker image won't work with the Automattic VIP infrastructure 😃" created="Thu, 12 Feb 2026 15:51:08 GMT"/>
          <outline text="I got curious, it turns out the VIP infrastructure has public docs " created="Thu, 12 Feb 2026 15:51:51 GMT">
            <outline text="https://docs.wpvip.com/infrastructure/" created="Thu, 12 Feb 2026 15:53:38 GMT" type="link" url="https://docs.wpvip.com/infrastructure/"/>
          </outline>
        </outline>
      </outline>
      <outline text="February 11" created="Wed, 11 Feb 2026 16:34:26 GMT" type="calendarDay" name="11">
        <outline text="Initial release of FeedLand Docker Install for public testing" created="Wed, 11 Feb 2026 16:34:27 GMT" type="outline">
          <outline text="I finally had to just get this out 😃" created="Wed, 11 Feb 2026 16:37:01 GMT"/>
          <outline text="Announcement: &lt;a href=&quot;https://wordland.shanson.de/2026/02/11/feedland-docker-compose/&quot;&gt;https://wordland.shanson.de/2026/02/11/feedland-docker-compose/&lt;/a&gt; " created="Wed, 11 Feb 2026 16:34:49 GMT"/>
          <outline text="Repo: &lt;a href=&quot;https://github.com/scotthansonde/feedlandDockerCompose&quot;&gt;https://github.com/scotthansonde/feedlandDockerCompose&lt;/a&gt;" created="Wed, 11 Feb 2026 16:35:23 GMT"/>
          <outline text="Running notes will be kept at &lt;a href=&quot;https://scott.this.how/feedlandDockerCompose.opml&quot;&gt;https://scott.this.how/feedlandDockerCompose.opml&lt;/a&gt;" created="Wed, 11 Feb 2026 16:35:59 GMT"/>
        </outline>
      </outline>
      <outline text="February 8" created="Sun, 08 Feb 2026 08:55:18 GMT" type="calendarDay" name="08">
        <outline text="First test of the install.sh script" created="Sun, 08 Feb 2026 15:37:31 GMT" type="outline">
          <outline text="It seems to work 👍. Just enter a hostname for FEEDLAND_DOMAIN, and everything starts up." created="Sun, 08 Feb 2026 15:37:48 GMT"/>
          <outline text="I need to think about edge cases." created="Sun, 08 Feb 2026 15:37:57 GMT">
            <outline text="Do we want caddy to start by default? Probably not, but I need to think about it." created="Sun, 08 Feb 2026 15:38:13 GMT">
              <outline text="You probably want a new caddy only if you are on a brand new server with a public IP with no other web apps " created="Sun, 08 Feb 2026 15:40:02 GMT"/>
            </outline>
            <outline text="If you don't enter a hostname at the prompt, it uses 'feedland.example.com' which guaranteed won't work." created="Sun, 08 Feb 2026 15:38:59 GMT">
              <outline text="We need to document how to correct this." created="Sun, 08 Feb 2026 15:41:13 GMT"/>
            </outline>
          </outline>
        </outline>
        <outline text="Finalizing Feedland Docker Install" created="Sun, 08 Feb 2026 08:55:19 GMT" type="outline">
          <outline text="https://github.com/scotthansonde/feedlandDockerCompose" created="Sun, 08 Feb 2026 09:02:47 GMT"/>
          <outline text="My first idea was to have the user edit an .env file and enter FEEDLAND_DOMAIN and the MySQL passwords" created="Sun, 08 Feb 2026 09:12:07 GMT">
            <outline text="That seems complicated, can we do a one- or two-step install" created="Sun, 08 Feb 2026 12:53:51 GMT"/>
          </outline>
          <outline text="How about an install.sh script that prompts for the domain name and generates the passwords?" created="Sun, 08 Feb 2026 09:13:15 GMT">
            <outline text="ChatGPT suggested a workflow and scripts, let's see how it works" created="Sun, 08 Feb 2026 12:53:19 GMT"/>
          </outline>
        </outline>
      </outline>
      <outline text="February 5" created="Thu, 05 Feb 2026 08:40:42 GMT" type="calendarDay" name="05">
        <outline text="&quot;scott, could we add source:markdown to daveverse.org/feed/&quot;" created="Thu, 05 Feb 2026 08:40:43 GMT" type="outline">
          <outline text="It looks like Chuck already installed the plugin 😃" created="Thu, 05 Feb 2026 08:41:36 GMT"/>
          <outline text="The plugin works on my own site too" created="Thu, 05 Feb 2026 08:44:33 GMT"/>
        </outline>
      </outline>
      <outline text="February 2" created="Mon, 02 Feb 2026 16:46:28 GMT" type="calendarDay" name="02">
        <outline text="Status of FeedLand Docker Install" created="Mon, 02 Feb 2026 16:46:29 GMT" type="outline">
          <outline text="It's basically done, I just need to write the docs and test it one more time" created="Mon, 02 Feb 2026 16:46:37 GMT"/>
        </outline>
      </outline>
      <outline text="February 1" created="Sun, 01 Feb 2026 08:32:27 GMT" type="calendarDay" name="01">
        <outline text="Manually set up a secondary site for a new user" created="Sun, 01 Feb 2026 16:45:05 GMT" type="outline">
          <outline text="https://duluth.shanson.de/" created="Sun, 01 Feb 2026 16:47:28 GMT"/>
          <outline text="New user was automatically created, password mail was sent" created="Sun, 01 Feb 2026 16:45:30 GMT"/>
          <outline text="Baseline was installed as the initial theme" created="Sun, 01 Feb 2026 16:45:47 GMT"/>
          <outline text="The user does not have wordpress.com account... what happens when we connect Jetpack?" created="Sun, 01 Feb 2026 16:46:04 GMT">
            <outline text="When I enter the email, it creates a wordpress.com account and makes up a funny username" created="Sun, 01 Feb 2026 16:49:37 GMT"/>
            <outline text="It connects and we get siteId in the HTML" created="Sun, 01 Feb 2026 16:53:30 GMT"/>
          </outline>
        </outline>
        <outline text="Questions and answers about WP Multisite" created="Sun, 01 Feb 2026 08:32:28 GMT" type="outline">
          <outline text="Terminology" created="Sun, 01 Feb 2026 08:32:37 GMT">
            <outline text="&quot;In a Multisite network, there’s always a primary site — known as the network site — that anchors the network. Additional sites, referred to as secondary sites, share plugins and themes, which are managed centrally at the network level. A Super Administrator oversees the network, ensuring smooth operations across all sites.&quot;" created="Sun, 01 Feb 2026 08:33:18 GMT"/>
            <outline text="Source: https://kinsta.com/blog/wp-cli-wordpress-multisite/ " created="Sun, 01 Feb 2026 08:33:44 GMT"/>
          </outline>
          <outline text="Can we set a default theme for new secondary sites?" created="Sun, 01 Feb 2026 08:35:56 GMT">
            <outline text="This can be set in wp-config.php: define( 'WP_DEFAULT_THEME', 'new-theme');" created="Sun, 01 Feb 2026 08:42:34 GMT"/>
          </outline>
          <outline text="Can we share mail settings among all secondary sites without the user having to enter SMTP settings?" created="Sun, 01 Feb 2026 08:36:51 GMT">
            <outline text="Yes, with FluentSTMP this we can do this" created="Sun, 01 Feb 2026 08:56:51 GMT"/>
            <outline text="Activate FluentSTMP only on the primary site, do not activate it for the network" created="Sun, 01 Feb 2026 08:57:17 GMT"/>
          </outline>
          <outline text="Can users change the site title and site icon for their secondary site?" created="Sun, 01 Feb 2026 08:45:56 GMT">
            <outline text="Yes, in the site dashboard under Settings-&gt;General, just like for a single Wordpress site" created="Sun, 01 Feb 2026 08:46:14 GMT"/>
            <outline text="Logon to the site dashboard under https://mysite.example.com/wp-admin" created="Sun, 01 Feb 2026 08:47:50 GMT"/>
          </outline>
          <outline text="Open questions" created="Sun, 01 Feb 2026 08:58:50 GMT">
            <outline text="Can we set up new users and secondary sites with the WP API?" created="Sun, 01 Feb 2026 08:36:14 GMT"/>
            <outline text="Can we map a domain to a secondary site with the WP API?" created="Sun, 01 Feb 2026 08:41:29 GMT"/>
            <outline text="Can we automatically connect a new secondary site with Jetpack to wordpress.com without the user having to do it manually?" created="Sun, 01 Feb 2026 08:37:13 GMT"/>
          </outline>
        </outline>
      </outline>
    </outline>

      <outline text="March 20" created="Fri, 20 Mar 2026 16:47:40 GMT" type="calendarDay" name="20">
        <outline text="Multisite WordPress, installed Jetpack" created="Fri, 20 Mar 2026 16:47:41 GMT" type="outline">
          <outline text="Activated for the main site, was able to post from legacy WordLand" created="Fri, 20 Mar 2026 16:47:56 GMT" type="link" url="https://wpzz.de/2026/03/20/test-post/"/>
